# This is an example file. Copy it to .env.local and fill in your credentials.
# These variables are used for client-side Firebase access.
# They are exposed to the browser and should be configured with appropriate security rules.
NEXT_PUBLIC_FIREBASE_API_KEY="your-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
NEXT_PUBLIC_FIREBASE_APP_ID="your-app-id"

# These variables are used for server-side Firebase Admin access.
# They are sensitive and MUST be kept secret. Do not commit them to your repository.
# In a production environment like Firebase App Hosting, store these as secrets.
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
# For the private key, copy the entire key from your service account JSON file.
# When storing as an environment variable (e.g., in .env.local or a secret manager),
# you might need to format it as a single line, replacing newlines with \n.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# NASA FIRMS API Key for fetching thermal anomaly data.
# Get your key from https://firms.modaps.eosdis.nasa.gov/api/api_key/
NASA_FIRMS_API_KEY="e554047808a5fdc4922408d6a7a725d6"
